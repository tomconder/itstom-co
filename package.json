    "babel-jest": "^25.1.0",
    "babel-plugin-styled-components": "^1.10.7",
    "chance": "^1.1.3",
    "check-prop-types": "^1.1.2",
    "cross-env": "^7.0.0",
    "enzyme": "^3.7.0",
    "enzyme-adapter-react-16": "^1.15.1",
    "enzyme-to-json": "^3.4.4",
    "eslint": "^6.6.0",
    "eslint-config-airbnb": "^18.0.0",
    "eslint-import-resolver-webpack": "^0.11.1",
