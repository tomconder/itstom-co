{
  "name": "itstom-co",
  "description": "It's Tom",
  "version": "1.0.6-beta",
  "author": "Tom Conder <tomc@itstom.co>",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/tomconder/itstom-co"
  },
  "scripts": {
    "build": "cross-env NODE_ENV=production gatsby build",
    "clean": "rimraf .cache public coverage reports",
    "develop": "gatsby develop",
    "deploy": "node scripts/deploy",
    "lint": "eslint --ignore-path .gitignore -c .eslintrc.json --ext js,jsx .",
    "lint:fix": "eslint --ignore-path .gitignore -c .eslintrc.json --ext js,jsx --fix .",
    "lint:sass": "sass-lint --config sass-lint.yml --verbose --no-exit 'src/**/**.scss'",
    "serve": "gatsby serve",
    "stryker": "cross-env NODE_ENV=test stryker run",
    "test": "cross-env NODE_ENV=test jest --no-cache",
    "test:coverage": "cross-env NODE_ENV=test jest --no-cache --coverage"
  },
  "dependencies": {
    "@reach/router": "^1.3.1",
    "classnames": "^2.2.6",
    "dotenv": "^8.2.0",
    "gatsby": "^2.19.12",
