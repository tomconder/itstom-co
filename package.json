{
  "name": "itstom-co",
  "description": "It's Tom",
  "version": "1.0.6-beta",
  "author": "Tom Conder <tomc@itstom.co>",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/tomconder/itstom-co"
  },
  "scripts": {
    "build": "cross-env NODE_ENV=production gatsby build",
    "clean": "rimraf .cache public coverage reports",
    "develop": "gatsby develop",
    "deploy": "node scripts/deploy",
    "lint": "eslint --ignore-path .gitignore -c .eslintrc.json --ext js,jsx .",
    "lint:fix": "eslint --ignore-path .gitignore -c .eslintrc.json --ext js,jsx --fix .",
    "lint:sass": "sass-lint --config sass-lint.yml --verbose --no-exit 'src/**/**.scss'",
    "serve": "gatsby serve",
    "stryker": "cross-env NODE_ENV=test stryker run",
    "test": "cross-env NODE_ENV=test jest --no-cache",
    "test:coverage": "cross-env NODE_ENV=test jest --no-cache --coverage"
  },
  "dependencies": {
    "@reach/router": "^1.3.4",
    "classnames": "^2.2.6",
    "dotenv": "^8.2.0",
    "gatsby": "^3.0.2",
    "gatsby-codemods": "^2.0.0",
    "gatsby-plugin-html-attributes": "^1.0.5",
    "gatsby-plugin-image": "^1.0.0",
    "gatsby-plugin-manifest": "^3.0.0",
    "gatsby-plugin-offline": "^4.0.0",
    "gatsby-plugin-purgecss": "^5.0.0",
    "gatsby-plugin-react-head": "^1.1.0",
    "gatsby-plugin-sass": "next",
    "gatsby-plugin-sharp": "^3.0.0",
    "gatsby-plugin-styled-components": "^4.0.0",
    "gatsby-source-filesystem": "^3.0.0",
    "gatsby-transformer-sharp": "^3.0.0",
    "prop-types": "^15.6.2",
    "raf": "^3.4.1",
    "react": "^17.0.1",
    "react-addons-shallow-compare": "^15.6.3",
    "react-dom": "^17.0.1",
    "react-feather": "^2.0.8",
    "react-head": "^3.1.1",
    "react-test-renderer": "^17.0.1",
    "sass": "^1.32.8",
    "sftp-sync-deploy": "^0.7.1",
    "styled-components": "^5.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.13.8",
    "@babel/plugin-proposal-class-properties": "^7.13.0",
    "@babel/plugin-proposal-optional-chaining": "^7.13.8",
    "@babel/preset-env": "^7.13.9",
    "@babel/preset-react": "^7.12.13",
    "@stryker-mutator/core": "^4.4.1",
    "@stryker-mutator/javascript-mutator": "^4.0.0",
    "@stryker-mutator/jest-runner": "^4.4.1",
